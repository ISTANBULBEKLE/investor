# Production environment for Oracle Cloud VM
# Copy to .env on the VM

DATABASE_URL=sqlite+aiosqlite:///./data/investor.db
BINANCE_BASE_URL=https://api.binance.com/api/v3
COINGECKO_API_KEY=
RESEND_API_KEY=re_xxxxxxxxxxxx
ALERT_EMAIL_TO=your@email.com
ALERT_EMAIL_FROM=onboarding@resend.dev
REDIS_URL=
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral
DEFAULT_SYMBOLS=["BTC","ETH","HBAR","IOTA"]
ANALYSIS_INTERVAL_MINUTES=30
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=investor-app/1.0
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
