# =============================================================================
# INVESTOR - Environment Variables
# Copy to backend/.env and frontend/.env.local respectively
# =============================================================================

# --- Backend (backend/.env) ---
DATABASE_URL=sqlite+aiosqlite:///./investor.db
BINANCE_BASE_URL=https://api.binance.com/api/v3
COINGECKO_API_KEY=                          # Optional - higher rate limits
DEFAULT_SYMBOLS=["BTC","ETH","HBAR","IOTA"]
ANALYSIS_INTERVAL_MINUTES=30

# Optional: Email alerts (https://resend.com - free)
RESEND_API_KEY=
ALERT_EMAIL_TO=your@email.com
ALERT_EMAIL_FROM=onboarding@resend.dev

# Optional: Reddit sentiment (https://reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=investor-app/1.0

# Optional: Local LLM (brew install ollama && ollama pull mistral)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# --- Frontend (frontend/.env.local) ---
BACKEND_URL=http://localhost:8000
BETTER_AUTH_SECRET=change-me-to-a-random-string
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
